{
  "extends": "./tsconfig.json",
  "include": [".generated/**/*"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "skipLibCheck": true,
    "checkJs": false,
    "noEmit": true,
    "rootDir": ".generated",
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/typescript/api-client-check.tsbuildinfo"
  }
}
