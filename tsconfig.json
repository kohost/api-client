{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "target": "ES2022",
    "moduleResolution": "node",
    "useUnknownInCatchVariables": true,
    "outDir": "./build",
    "strict": true,
    "declaration": true
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*"]
}
