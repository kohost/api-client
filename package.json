{
  "name": "@kohost/api-client",
  "version": "3.1.3",
  "description": "API client, models, schemas, commands, and events for Kohost applications",
  "author": "Ian Rogers",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/kohost/api-client"
  },
  "type": "module",
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "lint": "eslint ./",
    "lint:fix": "eslint --fix ./",
    "prepare": "node prepare.js",
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "start": "node scripts/build.js --watch",
    "clean": "rm -rf ./dist",
    "build:tsc": "tsc"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.1.0",
    "@kohost/eslint-config": "^1.0.0",
    "@types/amqplib": "^0.10.4",
    "@types/debug": "^4.1.12",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "esbuild": "^0.19.5",
    "eslint": "^8.56.0",
    "husky": "^8.0.1",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "typeconv": "^2.3.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.31.28",
    "ajv": "^8.11.0",
    "ajv-formats": "^2.1.1",
    "amqplib": "^0.10.3",
    "axios": "^1.0.0",
    "debug": "^4.3.4",
    "events": "^3.3.0",
    "nanoid": "^3.3.4",
    "socket.io-client": "^4.6.1"
  },
  "browser": {
    "events": "events"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,md,json}": "prettier --write"
  }
}
