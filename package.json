{
  "name": "@kohost/api-client",
  "version": "7.1.1",
  "description": "API client, models, schemas, commands, and events for Kohost applications",
  "author": "Ian Rogers",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kohost/api-client.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./dist/schemas/*.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./models/*": {
      "types": "./dist/models/*.d.ts",
      "default": "./dist/models/*.js"
    },
    "./useCases": {
      "types": "./dist/useCases/index.d.ts",
      "default": "./dist/useCases/index.js"
    },
    "./useCases/*": {
      "types": "./dist/useCases/*.d.ts",
      "default": "./dist/useCases/*.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./errors/*": {
      "types": "./dist/errors/*.d.ts",
      "default": "./dist/errors/*.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "default": "./dist/commands/index.js"
    },
    "./commands/*": {
      "types": "./dist/commands/*.d.ts",
      "default": "./dist/commands/*.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    },
    "./events/*": {
      "types": "./dist/events/*.d.ts",
      "default": "./dist/events/*.js"
    },
    "./client": {
      "types": "./dist/httpClient.d.ts",
      "default": "./dist/httpClient.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint --fix --cache --cache-location node_modules/.cache/eslint/ ./",
    "prepare": "husky || true",
    "prebuild": "npm run generate-models",
    "build": "npm run build:js -- --silent && npm run build:types",
    "build:js": "tsdown",
    "build:types": "tsc -b tsconfig.build.json --force && node scripts/add-js-extensions.js dist",
    "check-types": "npm run generate-models && tsc -p tsconfig.check.json",
    "prepublishOnly": "npm run build",
    "generate-models": "tsx scripts/generate-source-models.js",
    "clean:generated": "rm -rf .generated",
    "dev": "node scripts/dev-watcher.mjs",
    "start": "node scripts/dev-watcher.mjs",
    "clean": "rm -rf ./dist ./.generated",
    "tsc": "tsc",
    "tsdown": "tsdown"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/events": "^3.0.3",
    "@types/node": "^22.20.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "json-schema-to-ts": "^3.1.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,css,md,json}": "prettier --write"
  }
}
